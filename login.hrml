<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>AWD Login - Pull The Rope</title>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700;800&display=swap" rel="stylesheet">
<style>
  :root{ --cyan:#00D4FF; --purple:#8B5CF6; --orange:#FF7F00; --gradient: linear-gradient(90deg, #00D4FF 0%, #8B5CF6 50%, #FF7F00 100%); }
  body{margin:0; background:#050A1A; font-family:'Poppins', sans-serif; display:flex; justify-content:center; align-items:center; height:100vh; overflow:hidden; user-select:none}
  .room{width:100%; height:100%; display:flex; justify-content:center; align-items:center; flex-direction:column; background:radial-gradient(circle at 50% 10%, #0A1A3A 0%, #050A1A 70%)}
  .room h1{color:#fff; margin-bottom:20px; font-size:24px; text-align:center}
  
  /* LAMP */
  .lamp-container{cursor:pointer}
  .lamp{position:relative; animation:swing 3s ease-in-out infinite}
  @keyframes swing{0%,100%{transform:rotate(-4deg)} 50%{transform:rotate(4deg)}}
  .lamp-wire{width:2px; height:120px; background:#555; margin:0 auto}
  .lamp-body{width:90px; height:90px; background:var(--gradient); border-radius:50% 50% 40% 40%; box-shadow:0 0 50px rgba(139,92,246,0.7); transition:0.3s}
  .lamp-body.glow{box-shadow:0 0 80px rgba(139,92,246,1)}
  
  /* ROPE */
  .rope{width:4px; height:180px; background:linear-gradient(180deg, #8B4513, #5C2F0E); margin:0 auto; cursor:pointer; transition:0.3s; border-radius:2px; position:relative}
  .rope.pulled{transform:translateY(20px)}
  .rope::after{content:""; position:absolute; bottom:-10px; left:-8px; width:20px; height:20px; background:#8B4513; border-radius:50%}
  .pull-text{color:var(--orange); font-size:14px; margin-top:10px; font-weight:600; animation:blink 1.5s infinite}
  @keyframes blink{0%,100%{opacity:1} 50%{opacity:0.5}}
  
  /* LOGIN BOX */
  .login-box{display:none; background:#0F1430; padding:40px; border-radius:20px; border:2px solid var(--purple); text-align:center; margin-top:30px; animation:fadeIn 0.5s; width:90%; max-width:400px}
  @keyframes fadeIn{from{opacity:0; transform:translateY(-20px)} to{opacity:1; transform:translateY(0)}}
  .login-box h2{background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; font-size:28px; margin-bottom:20px}
  .login-box input{width:100%; padding:15px; margin:12px 0; background:#050A1A; border:1px solid #1E2758; border-radius:10px; color:#fff; font-size:16px; box-sizing:border-box}
  .login-box button{width:100%; padding:15px; background:var(--gradient); border:none; border-radius:10px; color:#000; font-weight:800; font-size:16px; cursor:pointer}
  .error{color:#FF4444; margin-top:10px; display:none; font-weight:600}
  .hint{color:#9AA0B4; font-size:12px; margin-top:15px}
</style>
</head>
<body>
<div class="room">
  <h1>Pull The Rope To Login</h1>
  
  <!-- LAMP WITH ROPE - PURA CLICKABLE -->
  <div class="lamp-container" onclick="toggleLogin()">
    <div class="lamp">
      <div class="lamp-wire"></div>
      <div class="lamp-body" id="lampBody"></div>
    </div>
    <div class="rope" id="rope"></div>
    <div class="pull-text">Click Here To Pull</div>
  </div>

  <!-- LOGIN FORM -->
  <div class="login-box" id="loginBox">
    <h2>Admin Login</h2>
    <input type="text" id="username" placeholder="Enter Username" required>
    <input type="password" id="password" placeholder="Enter Password" required>
    <button onclick="checkLogin()">Login</button>
    <p class="error" id="errorMsg">Wrong Username or Password!</p>
    <p class="hint">Demo: Username = admin | Password = adarsh123</p>
  </div>
</div>

<script>
  let isOpen = false;

  function toggleLogin(){
    const loginBox = document.getElementById('loginBox');
    const rope = document.getElementById('rope');
    const lamp = document.getElementById('lampBody');
    
    if(!isOpen){
      // ROPE PULL ANIMATION
      rope.classList.add('pulled');
      lamp.classList.add('glow');
      loginBox.style.display = 'block';
      isOpen = true;
    } else {
      // ROPE WAPAS
      rope.classList.remove('pulled');
      lamp.classList.remove('glow');
      loginBox.style.display = 'none';
      isOpen = false;
    }
  }

  function checkLogin(){
    const user = document.getElementById('username').value;
    const pass = document.getElementById('password').value;
    
    if(user === "admin" && pass === "adarsh123"){
      localStorage.setItem('awd_loggedIn', 'true');
      window.location.href = "index.html";
    } else {
      document.getElementById('errorMsg').style.display = 'block';
      setTimeout(()=>{document.getElementById('errorMsg').style.display = 'none'}, 3000);
    }
  }

  // ENTER KEY SE BHI LOGIN HO JAYE
  document.getElementById('password').addEventListener('keypress', function(e){
    if(e.key === 'Enter'){ checkLogin(); }
  })
</script>
</body>
</html>
